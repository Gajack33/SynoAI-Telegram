{
  "AllowedHosts": "*",

  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  },

  "Url": "http://YourIP:5000",
  "User": "",
  "Password": "",
  "AllowInsecureUrl": false,
  "AccessToken": "CHANGE_ME_LONG_RANDOM_TOKEN",
  "HttpTimeoutSeconds": 30,
  "SynologyTimeoutSeconds": 60,
  "TelegramTimeoutSeconds": 180,
  "MaxSnapshotBytes": 10485760,
  "MaxAIResponseBytes": 1048576,
  "MaxRecordingClipBytes": 52428800,

  "DrawMode": "Matches",
  "OutputJpegQuality": 100,

  "DaysToKeepCaptures": 14,
  "CapturePathPattern": "{camera}/{yyyy}/{MM}/{dd}",
  "PerfectShotEnabled": true,
  "DuplicateSnapshotIgnoreSeconds": 0,
  "StationaryObjectIgnoreSeconds": 300,
  "StationaryObjectMovementThresholdPixels": 25,

  "AI": {
    "Type": "CodeProjectAIServer",
    "Url": "http://YourIP:32168",
    "DetectionMode": "ObjectDetection",
    "Path": "v1/vision/custom/ipcam-general",
    "FaceRecognitionPath": "v1/vision/face/recognize",
    "FaceLabels": {
      "codeproject_user_id": "Display Name"
    },
    "TimeoutSeconds": 15,
    "FailureDelayMs": 30000,
    "MaxImageWidth": 1280,
    "JpegQuality": 85,
    "WarmupEnabled": true,
    "WarmupRetries": 10,
    "WarmupDelayMs": 5000
  },

  "Notifiers": [
    {
      "Type": "Telegram",
      "ChatID": "TELEGRAM_CHAT_ID",
      "Token": "TELEGRAM_BOT_TOKEN",
      "Language": "en",
      "PhotoBaseURL": "",
      "SendRecordingClip": false,
      "RecordingClipDownloadDelayMs": 30000,
      "RecordingClipOffsetMs": 0,
      "RecordingClipDurationMs": 60000
    }
  ],

  "Cameras": [
    {
      "Name": "Example1",
      "Types": [ "Person" ],
      "Threshold": 50,
      "MinSizeX": 25,
      "MinSizeY": 50,
      "Exclusions": [
        {
          "Start": { "X": 10, "Y": 10 },
          "End": { "X": 100, "Y": 100 }
        }
      ]
    },
    {
      "Name": "Example2",
      "Types": [ "Car", "Truck" ],
      "Threshold": 75
    },
    {
      "Name": "Example3",
      "Types": [ "Cat" ],
      "Threshold": 40,
      "Wait": 2500
    }
  ]
}
