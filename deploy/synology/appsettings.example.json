{
  "AllowedHosts": "*",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "Url": "http://NAS_IP:5000",
  "User": "SURVEILLANCE_STATION_USER",
  "Password": "SURVEILLANCE_STATION_PASSWORD",
  "AllowInsecureUrl": false,
  "AccessToken": "CHANGE_ME_LONG_RANDOM_TOKEN",
  "HttpTimeoutSeconds": 30,
  "HttpRetryCount": 2,
  "HttpRetryDelayMs": 1000,
  "SynologyTimeoutSeconds": 60,
  "TelegramTimeoutSeconds": 180,

  "Quality": "Balanced",
  "DrawMode": "Matches",
  "DrawExclusions": false,
  "OutputJpegQuality": 100,
  "DaysToKeepCaptures": 14,
  "Delay": 5000,
  "DelayAfterSuccess": 60000,
  "MaxSnapshots": 2,
  "MinSizeX": 50,
  "MinSizeY": 50,

  "AI": {
    "Type": "CodeProjectAIServer",
    "Url": "http://codeproject-ai:32168",
    "Path": "v1/vision/custom/ipcam-general",
    "TimeoutSeconds": 15,
    "FailureDelayMs": 30000,
    "MaxImageWidth": 1280,
    "JpegQuality": 85,
    "WarmupEnabled": true,
    "WarmupRetries": 10,
    "WarmupDelayMs": 5000
  },

  "Notifiers": [
    {
      "Type": "Telegram",
      "ChatID": "TELEGRAM_CHAT_ID",
      "Token": "TELEGRAM_BOT_TOKEN",
      "Language": "en",
      "PhotoBaseURL": "",
      "MessageThreadID": null,
      "CameraMessageThreadIDs": {
        "CAMERA_NAME_EXACTLY_AS_IN_SURVEILLANCE_STATION": 123
      },
      "SendRecordingClip": false,
      "RecordingClipDownloadDelayMs": 30000,
      "RecordingClipOffsetMs": 0,
      "RecordingClipDurationMs": 60000
    }
  ],

  "Cameras": [
    {
      "Name": "CAMERA_NAME_EXACTLY_AS_IN_SURVEILLANCE_STATION",
      "Types": [ "Person" ],
      "Threshold": 50,
      "MinSizeX": 40,
      "MinSizeY": 80,
      "Wait": 1000
    }
  ]
}
